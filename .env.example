# Required by the SEC for programmatic EDGAR access.
SEC_USER_AGENT=Your Name your.email@example.com

# Local data root for Docker bind mounts.
LOCAL_DATA_ROOT=/path/to/your/sec-edgar-data

# SEC EDGAR filing .htm files — keep EDGAR_HOST_PATH aligned with EDGAR_DOWNLOAD_BASE
SEC_EDGAR_DOCUMENT_ROOT=${LOCAL_DATA_ROOT}/edgar-filings
EDGAR_HOST_PATH=${SEC_EDGAR_DOCUMENT_ROOT}
EDGAR_DOWNLOAD_BASE=${SEC_EDGAR_DOCUMENT_ROOT}

MONGO_HOST_PATH=${LOCAL_DATA_ROOT}/mongo-data
KAFKA_HOST_PATH=${LOCAL_DATA_ROOT}/kafka-data

MONGO_URI=mongodb://mongo:27017
MONGO_DB=sec_edgar_filings

KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_FILING_DOWNLOADED_TOPIC=filings
