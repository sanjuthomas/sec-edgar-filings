# Required by the SEC for programmatic EDGAR access.
SEC_USER_AGENT=Your Name your.email@example.com

# Host path to the external drive; mounted into containers at the same path
# so local_path metadata stays consistent with files on disk.
EDGAR_HOST_PATH=/Volumes/Transcend/edgar

# Inside the container (keep aligned with the mount target below).
EDGAR_DOWNLOAD_BASE=/Volumes/Transcend/edgar

MONGO_URI=mongodb://mongo:27017
MONGO_DB=sec_edgar_filings

KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_FILING_DOWNLOADED_TOPIC=filings
